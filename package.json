{
  "name": "vitesse-react-ts",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "build": "tsc -b && vite build",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "release": "bumpp",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint:fmt": "pnpm run lint:fix && pnpm run fmt",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "ofetch": "^1.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "browserslist": "^4.28.5",
    "bumpp": "^11.1.0",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.24.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged",
    "pre-push": "pnpm run build"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint:fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
